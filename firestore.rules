rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Since we are using firebase-admin on the server, these rules 
    // are for direct client SDK access (if ever implemented).
    // The server-side admin SDK bypasses these rules.
    
    match /brands/{brandId} {
      allow read, write: if isSignedIn();
    }
    
    match /settings/{docId} {
      allow read, write: if isSignedIn();
    }
    
    match /logs/{logId} {
      allow read, write: if isSignedIn();
    }
    
    match /media/{mediaId} {
      allow read, write: if isSignedIn();
    }
    
    match /history/{historyId} {
      allow read, write: if isSignedIn();
    }
  }
}
